# 研域前沿综述 - 公网部署环境变量模板
# 使用方法：复制为 .env，并填入你自己的密钥。不要把 .env 提交到公开仓库。

# -----------------------------------------------------------------------------
# 公开站点与安全
# -----------------------------------------------------------------------------
# 公网域名。多个来源用英文逗号分隔，例如：https://your-domain.example,https://www.example.com
CORS_ORIGINS=https://your-domain.example

# Docker 公网部署默认会强制校验管理员密码、签名密钥和 CORS 配置。
FRONTIER_REVIEW_REQUIRE_SECURE_CONFIG=true
FRONTIER_REVIEW_ALLOW_INSECURE_DEFAULTS=false
FRONTIER_REVIEW_ENABLE_DOCS=false
# 本地调试可设为 false，公网定时日报保持 true。
FRONTIER_REVIEW_ENABLE_SCHEDULER=true

# 管理员登录签名密钥。生产环境必须改成随机长字符串。
DAILY_REVIEW_ADMIN_SECRET=please-change-this-long-random-secret

# 初始管理员账号密码。生产环境必须修改。
DAILY_REVIEW_ADMIN_USERNAME=admin
DAILY_REVIEW_ADMIN_PASSWORD=please-change-admin-password

# 登录与公开翻译接口的基础限流。
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=10
TRANSLATION_RATE_LIMIT_PER_MINUTE=30
MAX_CACHED_IMAGE_BYTES=10485760
MAX_CACHED_PDF_BYTES=157286400

# 容器内持久化目录。docker-compose.yml 已映射到宿主机 ./data/frontier_review。
FRONTIER_REVIEW_DATA_DIR=/data/frontier_review

# 可选：全文/语料目录。docker-compose.yml 已映射到宿主机 ./data/corpora。
BIBLIOCN_CORPORA_DIR=/data/corpora

# -----------------------------------------------------------------------------
# OpenAI 兼容 LLM：用于检索词扩展、综述撰写、可选翻译与生图提示词
# -----------------------------------------------------------------------------
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# 文献检索源
# -----------------------------------------------------------------------------
# sciverse：仅使用 Sciverse
# paper_search：仅使用可公网部署的 Paper Search HTTP 适配源
# hybrid：优先 Paper Search，不足时用 Sciverse 补充
DAILY_REVIEW_LITERATURE_PROVIDER=hybrid

# 可选值：semantic,openalex,crossref,europepmc,hal,base,core,unpaywall
PAPER_SEARCH_SOURCES=semantic,openalex,crossref,europepmc,hal,base,core,unpaywall

# true 时会真实访问 DOI/URL 做有效性校验，质量更好但速度更慢。
PAPER_SEARCH_VALIDATE_LINKS=true

# -----------------------------------------------------------------------------
# Sciverse
# -----------------------------------------------------------------------------
SCIVERSE_API_TOKEN=
SCIVERSE_BASE_URL=https://api.sciverse.space

# -----------------------------------------------------------------------------
# Paper Search MCP 兼容环境变量
# 当前部署版不直接依赖本地 MCP 进程，而是读取这些变量调用对应公开 API。
# -----------------------------------------------------------------------------

# CORE：配置后启用 CORE 检索。
PAPER_SEARCH_MCP_CORE_API_KEY=
CORE_API_KEY=

# Semantic Scholar：可选，配置后提高速率限制。
PAPER_SEARCH_MCP_SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
# Semantic Scholar 官方审批邮件要求当前 key 全端点累计 1 request/second。
# 默认 1.15 秒一次，低于阈值；不要调到 1.0 以下。
SEMANTIC_SCHOLAR_MIN_INTERVAL_SECONDS=1.15

# Unpaywall/OpenAlex 联系邮箱：推荐填写真实邮箱。
PAPER_SEARCH_MCP_UNPAYWALL_EMAIL=
UNPAYWALL_EMAIL=
OPENALEX_MAILTO=

# 以下变量当前会被读取并保留给后续适配器；默认检索流程不依赖它们。
PAPER_SEARCH_MCP_ZENODO_ACCESS_TOKEN=
PAPER_SEARCH_MCP_GOOGLE_SCHOLAR_PROXY_URL=
PAPER_SEARCH_MCP_ACM_API_KEY=
PAPER_SEARCH_MCP_IEEE_API_KEY=

# -----------------------------------------------------------------------------
# 微信公众号模块（也可直接在 /admin/wechat 后台配置）
# -----------------------------------------------------------------------------
# 服务器公网出口 IP 需要加入微信公众号后台 IP 白名单。
# 当前模块支持创建草稿；是否能自动发布取决于公众号权限，本项目默认不自动发布。
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# -----------------------------------------------------------------------------
# 开放获取 PDF
# -----------------------------------------------------------------------------
# 文献证据页“获取 PDF 原文（测试）”只查找合法开放获取 PDF。
# 支持线索来自 Semantic Scholar openAccessPdf、Unpaywall、CORE、Europe PMC、
# HAL、BASE、Sciverse access_oa_url 和论文记录中已有的开放仓储 URL。
# 不会绕过出版社付费墙，也不会在服务器保存 PDF。

# 定时任务并发。多个主题同一北京时间触发时，最多同时跑几个主题。
# 建议 2 起步；服务器资源充足且外部 API 限流允许时再调到 3-4。
DAILY_REVIEW_SCHEDULER_CONCURRENCY=2

